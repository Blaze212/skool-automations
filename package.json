{
  "name": "skool-automations",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "scripts": {
    "chatbot-mvp": "doppler run -- tsx scripts/chatbot-mvp.ts",
    "typecheck:functions": "cd supabase/functions && deno check **/*.ts",
    "format:functions": "cd supabase/functions && deno fmt",
    "lint:functions": "cd supabase/functions && deno lint",
    "test": "vitest run",
    "migrate:local": "supabase db push --db-url postgresql://postgres:postgres@127.0.0.1:54322/postgres",
    "functions:serve": "deno run --env-file=.env.local --allow-net --allow-env --allow-sys=hostname --config supabase/functions/deno.json supabase/functions/fractional-form-webhook/fractional-form-webhook.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@huggingface/transformers": "^3.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "googleapis": "^148.0.0",
    "skool-cli": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
