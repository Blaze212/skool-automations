{
  "compilerOptions": {
    "strict": true,
    "useUnknownInCatchVariables": false,
    "lib": ["deno.window"]
  },
  "tasks": {
    "check": "deno check **/*.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
