{
  "manifest_version": 3,
  "name": "Pipeline Tracker — drag to capture",
  "version": "0.0.2",
  "update_url": "https://raw.githubusercontent.com/Blaze212/skool-automations/main/pipeline-tracker/updates.xml",
  "key": "",
  "permissions": ["storage", "downloads", "sidePanel", "activeTab"],
  "externally_connectable": {
    "matches": ["https://app.cmcareersystems.com/*", "http://localhost:5173/*"]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_title": "Pipeline Tracker — open side panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
